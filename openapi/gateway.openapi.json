{
  "components": {
    "schemas": {
      "DocumentIngestRequest": {
        "example": {
          "content": "def foo():\n    return 42\n",
          "filename": "main.py"
        },
        "properties": {
          "chunk_size": {
            "default": 500,
            "maximum": 10000.0,
            "minimum": 50.0,
            "title": "Chunk Size",
            "type": "integer"
          },
          "content": {
            "minLength": 1,
            "title": "Content",
            "type": "string"
          },
          "filename": {
            "maxLength": 512,
            "minLength": 1,
            "title": "Filename",
            "type": "string"
          }
        },
        "required": [
          "filename",
          "content"
        ],
        "title": "DocumentIngestRequest",
        "type": "object"
      },
      "DocumentIngestResponse": {
        "properties": {
          "filename": {
            "title": "Filename",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "num_chunks": {
            "title": "Num Chunks",
            "type": "integer"
          }
        },
        "required": [
          "message",
          "num_chunks",
          "filename"
        ],
        "title": "DocumentIngestResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "properties": {
          "service": {
            "title": "Service",
            "type": "string"
          },
          "status": {
            "default": "ok",
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "service"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "QueryRequest": {
        "example": {
          "question": "What does foo return?"
        },
        "properties": {
          "question": {
            "maxLength": 4000,
            "minLength": 1,
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question"
        ],
        "title": "QueryRequest",
        "type": "object"
      },
      "QueryResponse": {
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "context_preview": {
            "description": "Short preview of retrieved chunk",
            "title": "Context Preview",
            "type": "string"
          }
        },
        "required": [
          "answer",
          "context_preview"
        ],
        "title": "QueryResponse",
        "type": "object"
      },
      "ReadinessResponse": {
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          },
          "ready": {
            "title": "Ready",
            "type": "boolean"
          },
          "service": {
            "title": "Service",
            "type": "string"
          }
        },
        "required": [
          "ready",
          "service"
        ],
        "title": "ReadinessResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "BFF orchestrating ingest and RAG microservices",
    "title": "sorakAi Gateway",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Root",
        "tags": [
          "ops"
        ]
      }
    },
    "/api/v1/documents": {
      "post": {
        "operationId": "proxy_ingest_api_v1_documents_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentIngestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentIngestResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Proxy Ingest",
        "tags": [
          "documents"
        ]
      }
    },
    "/api/v1/query": {
      "post": {
        "operationId": "proxy_query_api_v1_query_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Proxy Query",
        "tags": [
          "rag"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "ops"
        ]
      }
    },
    "/ready": {
      "get": {
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Ready",
        "tags": [
          "ops"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Ingest pipeline",
      "name": "documents"
    },
    {
      "description": "Question answering",
      "name": "rag"
    },
    {
      "description": "Health and readiness",
      "name": "ops"
    }
  ]
}
