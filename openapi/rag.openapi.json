            "type": "string"
          }
        },
        "required": [
          "service"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "QueryRequest": {
        "example": {
          "question": "What does foo return?"
        },
        "properties": {
          "question": {
            "maxLength": 4000,
            "minLength": 1,
            "title": "Question",
            "type": "string"
          }
        },
        "required": [
          "question"
        ],
        "title": "QueryRequest",
        "type": "object"
      },
      "QueryResponse": {
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "context_preview": {
            "description": "Short preview of retrieved chunk",
            "title": "Context Preview",
            "type": "string"
          }
        },
        "required": [
          "answer",
          "context_preview"
        ],
        "title": "QueryResponse",
        "type": "object"
      },
      "ReadinessResponse": {
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
